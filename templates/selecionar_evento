<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <title>Selecionar Evento</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- CSS GLOBAL -->
    <link rel="stylesheet" href="{{ url_for('static', filename='css/style.css') }}">

    <style>
        body {
            background-color: #000;
            color: #FFF;
        }

        .container-box {
            max-width: 500px;
            margin: 100px auto;
            background-color: #111;
            padding: 30px;
            border-radius: 10px;
        }

        .btn-primary {
            background-color: #0d3b66;
            border: none;
        }

        .btn-primary:hover {
            background-color: #145ea8;
        }

        select {
            background-color: #000 !important;
            color: #FFF !important;
            border: 1px solid #444 !important;
        }

        select:focus {
            border-color: #0d3b66 !important;
            box-shadow: none !important;
        }

        header {
            background-color: #000;
            padding: 10px 20px;
            border-bottom: 1px solid #222;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        header img {
            height: 40px;
        }

        header h5 {
            margin: 0;
        }
    </style>
</head>
<body>

<!-- HEADER FIXO -->
<header>
    <div class="d-flex align-items-center gap-3">
        <img src="{{ url_for('static', filename='Hub_de_Imagens/logo.png') }}">
        <h5>Sistema de Presença</h5>
    </div>

    <div>
        <a href="{{ url_for('logout') }}" class="btn btn-sm btn-danger">Sair</a>
    </div>
</header>

<!-- CONTEÚDO -->
<div class="container-box">

    <h4 class="text-center mb-4">Selecionar Evento / Contrato</h4>

    <form method="POST">

        <label class="form-label">Escolha:</label>
        <select name="evento" class="form-control" required>
            <option value="">Selecione...</option>

            {% for evento in eventos %}
                <option value="{{ evento.id }}">
                    {{ evento.nome }} ({{ evento.tipo }})
                </option>
            {% endfor %}
        </select>

        <button type="submit" class="btn btn-primary w-100 mt-4">
            Continuar
        </button>

    </form>

</div>

</body>
</html>
